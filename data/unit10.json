      "question": "sum 1/n^p converges when:",
      "choices": {
        "A": "p<=1",
        "B": "p>1",
        "C": "p=1 only",
        "D": "always"
      },
      "correct": "B",
      "explanation": "p-series converges iff p>1.",
      "notesSection": "10.3 - p-Series",
      "notesSnippet": "This is a must-memorize test.",
      "timeTip": "Compare quickly to p=1 benchmark."
